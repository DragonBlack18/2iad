// ============================================
// SISTEMA DE PLANILHAS (CORE DO SISTEMA)
// ============================================

model Planilha {
  id               String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome             String                @db.VarChar(255)
  descricao        String?
  startup_id       String                @db.Uuid
  criado_por       String                @db.Uuid
  atualizado_por   String?               @db.Uuid
  versao           Int                   @default(1)
  ativa            Boolean               @default(true)
  template         Boolean               @default(false)
  config           Json?
  created_at       DateTime              @default(now()) @db.Timestamp(6)
  updated_at       DateTime              @default(now()) @db.Timestamp(6)
  startup          Startup               @relation(fields: [startup_id], references: [id], onDelete: Cascade)
  criador          User                  @relation("PlanilhaCriador", fields: [criado_por], references: [id])
  atualizador      User?                 @relation("PlanilhaAtualizador", fields: [atualizado_por], references: [id])
  colunas          PlanilhaColuna[]
  linhas           PlanilhaLinha[]
  permissoes       PlanilhaPermissao[]
  versoes          PlanilhaVersao[]

  @@index([startup_id], map: "idx_planilhas_startup")
  @@index([ativa], map: "idx_planilhas_ativa")
  @@map("planilhas")
}

model PlanilhaColuna {
  id           String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  planilha_id  String           @db.Uuid
  nome         String           @db.VarChar(255)
  tipo         String           @db.VarChar(50) // TEXT, NUMBER, DATE, BOOLEAN, SELECT, FORMULA
  largura      Int?             @default(150)
  ordem        Int              @default(0)
  obrigatoria  Boolean          @default(false)
  opcoes       String[]         // Para tipo SELECT
  formula      String?          // Para tipo FORMULA
  formato      String?          @db.VarChar(50) // Formatação (moeda, percentual, etc)
  visivel      Boolean          @default(true)
  editavel     Boolean          @default(true)
  created_at   DateTime         @default(now()) @db.Timestamp(6)
  planilha     Planilha         @relation(fields: [planilha_id], references: [id], onDelete: Cascade)
  celulas      PlanilhaCelula[]

  @@index([planilha_id], map: "idx_colunas_planilha")
  @@map("planilha_colunas")
}

model PlanilhaLinha {
  id          String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  planilha_id String           @db.Uuid
  ordem       Int              @default(0)
  dados       Json?            // Cache dos dados da linha para performance
  created_at  DateTime         @default(now()) @db.Timestamp(6)
  updated_at  DateTime         @default(now()) @db.Timestamp(6)
  planilha    Planilha         @relation(fields: [planilha_id], references: [id], onDelete: Cascade)
  celulas     PlanilhaCelula[]

  @@index([planilha_id], map: "idx_linhas_planilha")
  @@map("planilha_linhas")
}

model PlanilhaCelula {
  id         String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  linha_id   String         @db.Uuid
  coluna_id  String         @db.Uuid
  valor      String?        // Valor como texto
  valor_num  Decimal?       @db.Decimal(20, 6) // Valor numérico para cálculos
  valor_bool Boolean?       // Valor booleano
  valor_data DateTime?      @db.Timestamp(6) // Valor data
  formula    String?        // Fórmula se aplicável
  validado   Boolean        @default(true)
  erro       String?        // Mensagem de erro se houver
  created_at DateTime       @default(now()) @db.Timestamp(6)
  updated_at DateTime       @default(now()) @db.Timestamp(6)
  linha      PlanilhaLinha  @relation(fields: [linha_id], references: [id], onDelete: Cascade)
  coluna     PlanilhaColuna @relation(fields: [coluna_id], references: [id], onDelete: Cascade)

  @@unique([linha_id, coluna_id])
  @@index([linha_id], map: "idx_celulas_linha")
  @@index([coluna_id], map: "idx_celulas_coluna")
  @@map("planilha_celulas")
}

model PlanilhaPermissao {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  planilha_id String   @db.Uuid
  user_id     String   @db.Uuid
  nivel       String   @db.VarChar(50) // LEITURA, ESCRITA, ADMIN
  created_at  DateTime @default(now()) @db.Timestamp(6)
  planilha    Planilha @relation(fields: [planilha_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([planilha_id, user_id])
  @@index([planilha_id], map: "idx_permissoes_planilha")
  @@index([user_id], map: "idx_permissoes_user")
  @@map("planilha_permissoes")
}

model PlanilhaVersao {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  planilha_id String   @db.Uuid
  versao      Int
  snapshot    Json     // Snapshot completo da planilha
  criado_por  String   @db.VarChar(255)
  comentario  String?
  created_at  DateTime @default(now()) @db.Timestamp(6)
  planilha    Planilha @relation(fields: [planilha_id], references: [id], onDelete: Cascade)

  @@index([planilha_id], map: "idx_versoes_planilha")
  @@map("planilha_versoes")
}

// ============================================
// SISTEMA DE MÍDIA E LOGS
// ============================================

model Media {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome_original String    @db.VarChar(255)
  nome_arquivo  String    @db.VarChar(255)
  caminho       String
  url           String
  mime_type     String    @db.VarChar(100)
  tamanho       Int       // Em bytes
  largura       Int?      // Para imagens
  altura        Int?      // Para imagens
  tipo          String    @db.VarChar(50) // IMAGE, VIDEO, DOCUMENT, OTHER
  pasta         String?   @db.VarChar(100)
  relacionado_tipo String? @db.VarChar(50) // startup, edital, parceiro, user
  relacionado_id   String? @db.Uuid
  criado_por    String?   @db.Uuid
  descricao     String?
  tags          String[]
  publico       Boolean   @default(false)
  created_at    DateTime  @default(now()) @db.Timestamp(6)

  @@index([tipo], map: "idx_media_tipo")
  @@index([relacionado_tipo, relacionado_id], map: "idx_media_relacionado")
  @@index([criado_por], map: "idx_media_criado_por")
  @@map("media")
}

model Log {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String?  @db.Uuid
  acao       String   @db.VarChar(100)
  entidade   String   @db.VarChar(50)
  entidade_id String? @db.Uuid
  dados_antes Json?
  dados_depois Json?
  ip         String?  @db.VarChar(45)
  user_agent String?
  created_at DateTime @default(now()) @db.Timestamp(6)
  user       User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id], map: "idx_logs_user")
  @@index([entidade, entidade_id], map: "idx_logs_entidade")
  @@index([created_at], map: "idx_logs_data")
  @@map("logs")
}
