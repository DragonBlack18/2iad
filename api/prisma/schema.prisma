generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                            String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome                                          String              @db.VarChar(255)
  email                                         String              @unique @db.VarChar(255)
  senha                                         String              @db.VarChar(255)
  telefone                                      String?             @db.VarChar(20)
  cpf                                           String?             @unique @db.VarChar(14)
  tipo                                          String?             @default("EMPREENDEDOR") @db.VarChar(50)
  role                                          String              @default("INCUBADO") @db.VarChar(50)
  startup_id                                    String?             @db.Uuid
  avatar                                        String?
  bio                                           String?
  linkedin                                      String?             @db.VarChar(255)
  website                                       String?             @db.VarChar(255)
  created_at                                    DateTime?           @default(now()) @db.Timestamp(6)
  updated_at                                    DateTime?           @default(now()) @db.Timestamp(6)
  ativo                                         Boolean?            @default(true)
  ultimo_acesso                                 DateTime?           @db.Timestamp(6)
  artigos                                       artigos[]
  candidaturas_candidaturas_avaliador_idTousers candidaturas[]      @relation("candidaturas_avaliador_idTousers")
  candidaturas_candidaturas_user_idTousers      candidaturas[]      @relation("candidaturas_user_idTousers")
  evento_inscricoes                             evento_inscricoes[]
  mensagens_mensagens_destinatario_idTousers    mensagens[]         @relation("mensagens_destinatario_idTousers")
  mensagens_mensagens_remetente_idTousers       mensagens[]         @relation("mensagens_remetente_idTousers")
  mentores                                      mentores[]
  notificacoes                                  notificacoes[]
  reservas                                      reservas[]
  startup_membros                               startup_membros[]
  startups                                      Startup[]
  logs                                          Log[]
  planilhas_criadas                             Planilha[]          @relation("PlanilhaCriador")
  planilhas_atualizadas                         Planilha[]          @relation("PlanilhaAtualizador")
  planilha_permissoes                           PlanilhaPermissao[]

  @@index([ativo], map: "idx_users_ativo")
  @@index([email], map: "idx_users_email")
  @@index([tipo], map: "idx_users_tipo")
  @@index([role], map: "idx_users_role")
  @@index([startup_id], map: "idx_users_startup")
  @@map("users")
}

model Startup {
  id                 String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome               String               @db.VarChar(255)
  slug               String               @unique @db.VarChar(255)
  descricao          String?
  descricao_completa String?
  logo               String?
  banner             String?
  setor              String?              @db.VarChar(100)
  modelo_negocio     String?              @db.VarChar(100)
  status             String?              @default("PRE_INCUBACAO") @db.VarChar(50)
  fundacao_ano       Int?
  website            String?              @db.VarChar(255)
  email              String?              @db.VarChar(255)
  telefone           String?              @db.VarChar(20)
  cnpj               String?              @db.VarChar(18)
  endereco           String?
  cidade             String?              @db.VarChar(100)
  estado             String?              @db.VarChar(2)
  pitch_deck         String?
  video_pitch        String?
  redes_sociais      Json?
  metricas           Json?
  fundador_id        String?              @db.Uuid
  data_entrada       DateTime?            @db.Date
  data_graduacao     DateTime?            @db.Date
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  updated_at         DateTime?            @default(now()) @db.Timestamp(6)
  candidaturas       candidaturas[]
  evento_inscricoes  evento_inscricoes[]
  reservas           reservas[]
  sessoes_mentoria   sessoes_mentoria[]
  startup_documentos startup_documentos[]
  startup_imagens    startup_imagens[]
  startup_membros    startup_membros[]
  planilhas          Planilha[]
  users              User?                @relation(fields: [fundador_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([fundador_id], map: "idx_startups_fundador")
  @@index([setor], map: "idx_startups_setor")
  @@index([slug], map: "idx_startups_slug")
  @@index([status], map: "idx_startups_status")
  @@map("startups")
}

model Edital {
  id                      String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  titulo                  String         @db.VarChar(255)
  slug                    String         @unique @db.VarChar(255)
  descricao               String?
  descricao_completa      String?
  imagem_capa             String?
  tipo                    String?        @db.VarChar(50)
  status                  String?        @default("RASCUNHO") @db.VarChar(50)
  data_abertura           DateTime?      @db.Date
  data_encerramento       DateTime?      @db.Date
  vagas                   Int?
  requisitos              String[]
  beneficios              String[]
  etapas                  Json?
  documentos_necessarios  String[]
  criterios_avaliacao     Json?
  arquivo_edital          String?
  investimento_disponivel Decimal?       @db.Decimal(15, 2)
  created_at              DateTime?      @default(now()) @db.Timestamp(6)
  updated_at              DateTime?      @default(now()) @db.Timestamp(6)
  candidaturas            candidaturas[]

  @@index([data_abertura, data_encerramento], map: "idx_editais_datas")
  @@index([slug], map: "idx_editais_slug")
  @@index([status], map: "idx_editais_status")
  @@map("editais")
}

model Parceiro {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome             String    @db.VarChar(255)
  slug             String    @unique @db.VarChar(255)
  descricao        String?
  logo             String?
  banner           String?
  tipo             String?   @db.VarChar(50)
  categoria        String?   @db.VarChar(100)
  website          String?   @db.VarChar(255)
  email            String?   @db.VarChar(255)
  telefone         String?   @db.VarChar(20)
  endereco         String?
  cidade           String?   @db.VarChar(100)
  estado           String?   @db.VarChar(2)
  redes_sociais    Json?
  beneficios       String[]
  areas_atuacao    String[]
  contato_nome     String?   @db.VarChar(255)
  contato_cargo    String?   @db.VarChar(100)
  contato_email    String?   @db.VarChar(255)
  contato_telefone String?   @db.VarChar(20)
  data_parceria    DateTime? @db.Date
  ativo            Boolean?  @default(true)
  destaque         Boolean?  @default(false)
  ordem            Int?      @default(0)
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  updated_at       DateTime? @default(now()) @db.Timestamp(6)

  @@index([ativo], map: "idx_parceiros_ativo")
  @@index([slug], map: "idx_parceiros_slug")
  @@index([tipo], map: "idx_parceiros_tipo")
  @@map("parceiros")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model artigos {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  titulo          String    @db.VarChar(255)
  slug            String    @unique @db.VarChar(255)
  resumo          String?
  conteudo        String
  imagem_capa     String?
  autor_id        String?   @db.Uuid
  categoria       String?   @db.VarChar(100)
  tags            String[]
  publicado       Boolean?  @default(false)
  data_publicacao DateTime? @db.Timestamp(6)
  visualizacoes   Int?      @default(0)
  tempo_leitura   Int?
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  updated_at      DateTime? @default(now()) @db.Timestamp(6)
  users           User?     @relation(fields: [autor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model candidaturas {
  id                                     String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  edital_id                              String?   @db.Uuid
  user_id                                String?   @db.Uuid
  startup_id                             String?   @db.Uuid
  status                                 String?   @default("ENVIADA") @db.VarChar(50)
  pontuacao                              Decimal?  @db.Decimal(5, 2)
  feedback                               String?
  documentos                             Json?
  etapa_atual                            String?   @db.VarChar(100)
  data_candidatura                       DateTime? @default(now()) @db.Timestamp(6)
  data_avaliacao                         DateTime? @db.Timestamp(6)
  avaliador_id                           String?   @db.Uuid
  created_at                             DateTime? @default(now()) @db.Timestamp(6)
  updated_at                             DateTime? @default(now()) @db.Timestamp(6)
  users_candidaturas_avaliador_idTousers User?     @relation("candidaturas_avaliador_idTousers", fields: [avaliador_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  editais                                Edital?   @relation(fields: [edital_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  startups                               Startup?  @relation(fields: [startup_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_candidaturas_user_idTousers      User?     @relation("candidaturas_user_idTousers", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([edital_id], map: "idx_candidaturas_edital")
  @@index([status], map: "idx_candidaturas_status")
  @@index([user_id], map: "idx_candidaturas_user")
}

model configuracoes {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  chave      String    @unique @db.VarChar(100)
  valor      String?
  tipo       String?   @db.VarChar(50)
  descricao  String?
  updated_at DateTime? @default(now()) @db.Timestamp(6)
}

model evento_inscricoes {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  evento_id      String?   @db.Uuid
  user_id        String?   @db.Uuid
  startup_id     String?   @db.Uuid
  status         String?   @default("CONFIRMADA") @db.VarChar(50)
  data_inscricao DateTime? @default(now()) @db.Timestamp(6)
  data_presenca  DateTime? @db.Timestamp(6)
  eventos        eventos?  @relation(fields: [evento_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  startups       Startup?  @relation(fields: [startup_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users          User?     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
